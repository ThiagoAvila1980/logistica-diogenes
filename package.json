{
  "name": "fluxo-diogenes",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:mobile": "next dev --turbopack --hostname 0.0.0.0",
    "dev:webpack": "next dev",
    "dev:clean": "node scripts/dev-clean.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs migrate",
    "db:migrate-roles": "node --env-file=.env.local scripts/db-apply-user-roles.mjs",
    "db:migrate-drop-clients": "node --env-file=.env.local scripts/db-apply-drop-clients.mjs",
    "db:migrate-remove-revision": "node --env-file=.env.local scripts/db-apply-remove-revision.mjs",
    "db:migration-status": "node --env-file=.env.local scripts/db-migration-status.mjs",
    "db:sync-drizzle-journal": "node --env-file=.env.local scripts/db-sync-drizzle-journal.mjs",
    "db:studio": "node --env-file=.env.local ./node_modules/drizzle-kit/bin.cjs studio",
    "db:seed": "node --env-file=.env.local ./node_modules/tsx/dist/cli.mjs src/db/seed.ts",
    "db:ping": "node --env-file=.env.local scripts/db-ping.mjs",
    "db:fix-auth": "node --env-file=.env.local scripts/db-fix-auth.mjs",
    "db:indexes": "node --env-file=.env.local scripts/db-apply-indexes.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1052.0",

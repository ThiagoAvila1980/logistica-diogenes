# Supabase — Project Settings > Database
# Runtime (Session pooler, porta 6543) — copie do dashboard Supabase
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Migrations/seed (Session pooler, porta 5432)
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# PostgreSQL local (dev) — não use ?schema=public (parâmetro Prisma; quebra postgres.js)
DATABASE_URL=postgresql://postgres:senha@localhost:5432/db_logistica
DIRECT_URL=postgresql://postgres:senha@localhost:5432/db_logistica

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Storage (server-only): Project Settings > API > service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_STORAGE_BUCKET=uploads

# Storage: local (dev) | supabase (prod) — fallback R2 quando cota encher
# STORAGE_PRIMARY=supabase
# STORAGE_FALLBACK=r2

# Cloudflare R2 (fallback quando Supabase Storage encher)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=fluxo-uploads
# R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Resend — https://resend.com
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM_EMAIL=Logística Diógenes <noreply@seudominio.com>

# Z-API WhatsApp — https://developer.z-api.io/
ZAPI_INSTANCE_ID=sua_instancia
ZAPI_TOKEN=seu_token
ZAPI_CLIENT_TOKEN=seu_client_token_opcional

# Webhook ao criar medição (notifica medidores) — POST JSON
# MEDIDOR_WEBHOOK_URL=https://seu-automation.example/webhook/medidor
# URL pública do app (Coolify/prod) — usada no cookie Secure e links externos
NEXT_PUBLIC_APP_URL=https://www.diogenesvidros.com.br

# Sessão (obrigatório em produção — mesma chave em todos os containers)
# SESSION_SECRET=string-longa-aleatoria
# Se o site ainda não tiver HTTPS: COOKIE_SECURE=false

# WebAuthn / biometria (obrigatório no celular em produção)
# WEBAUTHN_RP_ID=seu-dominio.ngrok-free.app
# WEBAUTHN_ORIGIN=https://seu-dominio.ngrok-free.app
# BIOMETRIC_SECRET=string-longa-aleatoria
# BIOMETRIC_ALLOW_DEV_FALLBACK=true

# Uploads: sem SUPABASE_SERVICE_ROLE_KEY usa public/uploads/ (dev)
# Fotos são convertidas para WebP (Sharp) antes de salvar; máx. 5 MB
# UPLOAD_MAX_FILE_BYTES=5242880

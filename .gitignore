# temp scripts (ex.: geração de favicon — nunca commitar node_modules)
.tmp-favicon/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# env
.env
.env*.local

# uploads (conteúdo gerado em runtime)
/public/uploads/*
!/public/uploads/.gitkeep

# service worker gerado em build (Serwist)
/public/sw.js
/public/sw.js.map

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE
.idea
.vscode
*.swp

# site (landing — versionado para deploy; ignorar só artefatos locais)
/site/node_modules/
/site/.next/
/site/next-env.d.ts

# lockfile só na raiz (app principal usa npm install no CI)
/package-lock.json
